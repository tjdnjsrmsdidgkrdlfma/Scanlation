[Unit]
Description=llama.cpp translate server (MI50, Vulkan, gemma-4)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/opt/llama/llama.cpp/build-vulkan/bin/llama-server -hf unsloth/gemma-4-26B-A4B-it-qat-GGUF -ngl 99 -c 8192 --host 0.0.0.0 --port 8080
Restart=on-failure

[Install]
WantedBy=multi-user.target

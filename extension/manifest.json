{
  "manifest_version": 2,
  "name": "Scanlation",
  "version": "0.1.0",
  "description": "In-place manga OCR + translation overlay. Works with the Scanlation server.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_title": "Scanlation — settings",
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" }
  },
  "page_action": {
    "default_title": "Scanlation: click to translate this tab",
    "default_icon": { "16": "icons/icon-off16.png", "48": "icons/icon-off48.png" },
    "show_matches": ["http://*/*", "https://*/*", "file:///*"]
  },
  "background": {
    "scripts": ["src/constants.js", "src/util.js", "src/i18n.js", "src/background.js"],
    "persistent": false
  },
  "permissions": [
    "storage",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/constants.js", "src/util.js", "src/i18n.js", "src/md5.js", "src/content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": { "id": "scanlation@local" }
  }
}
